# ============================================================================
# TENBOT Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Discord Bot Token (get from https://discord.com/developers/applications)
BOT_TOKEN=your_bot_token_here

# Legacy phase 2 integrations
LEGACY_PHASE2_ENABLED=true
LEGACY_CAPTCHA_VERIFICATION=true
LEGACY_DM_PROTECTION=true
LEGACY_THREAT_INTELLIGENCE=true
LEGACY_ADVANCED_NETWORKING=true
LEGACY_EVENT_MANAGER=true
LEGACY_TOPIC_DETECTION=true
LEGACY_HUMANITY_FINGERPRINTING=true

# AI summary API (optional)
GROQ_API_KEY=your_groq_key_here
AI_SUMMARY_MODEL=llama-3.1-70b-versatile

# Voice transcription provider
# local = faster-whisper on your machine
# deepgram = external realtime API
STT_PROVIDER=local
VC_TRANSCRIPTION_ENABLED=true
VC_TRANSCRIPTION_MODEL=base
VC_TRANSCRIPTION_COMPUTE_TYPE=int8

# Deepgram (only needed if STT_PROVIDER=deepgram)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2

# Future: Other AI API keys (optional)
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
# GOOGLE_CLOUD_API_KEY=your_google_key_here
